---
import { getCollection } from "astro:content";
import PostFeed from "@/components/PostFeed.astro";
import TagRefine from "@/theme/components/TagRefine.astro";
import PageLayout from "@/theme/layouts/PageLayout.astro";
import { knownTags } from "@/theme/lib/knownTags";
import { tagSlug } from "@/theme/lib/tags";

const all = await getCollection("posts", ({ data }) => !data.draft && !data.unlisted);

const sorted = [...all].sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const allTagSlugs = new Set<string>(knownTags);
for (const p of all) for (const t of p.data.tags) allTagSlugs.add(tagSlug(t));
const allTags = [...allTagSlugs].sort();

const manifest = sorted.map((p) => ({
	id: p.id,
	tags: p.data.tags.map(tagSlug),
}));

const presentEmpty = new Set<string>();
---

<PageLayout
	current="posts"
	title="Posts — Append Only"
	description="Everything I've written, most recent first."
>
	<header class="mb-10" data-q-header>
		<div
			class="font-mono text-[11px] text-fg-faint tracking-[0.12em] uppercase mb-2"
			data-q-kicker
		>
			Posts
		</div>
		<h1
			class="font-serif font-medium text-[44px] leading-[1.05] tracking-[-0.02em] mb-3"
			data-q-title
		>
			All posts
		</h1>
		<p class="text-fg-dim text-[15px]">
			<span data-q-count>{sorted.length}</span>
			<span data-q-noun>{sorted.length === 1 ? "post" : "posts"}</span>.
			<span class="text-fg-faint font-mono text-[12px] ml-2" data-q-path
				>/posts/q/</span
			>
		</p>
	</header>

	<div class="mb-10" data-q-tagrefine>
		<TagRefine segments={[]} allTags={allTags} presentTags={presentEmpty} />
	</div>

	<div data-q-feed>
		<PostFeed entries={sorted} showExcerpt />
	</div>
	<p
		class="text-fg-dim text-[15px] italic mt-4"
		data-q-empty
		hidden
	>
		No posts match this query.
	</p>

	<script
		type="application/json"
		data-q-manifest
		set:html={JSON.stringify(manifest)}
	/>
	<script
		type="application/json"
		data-q-tags
		set:html={JSON.stringify(allTags)}
	/>
</PageLayout>

<script>
	import { evaluate, parse } from "@/lib/tagfs";

	type ManifestItem = { id: string; tags: string[] };

	const ROOT = "/posts/q/";

	const manifestEl = document.querySelector<HTMLScriptElement>(
		"[data-q-manifest]",
	);
	const tagsEl = document.querySelector<HTMLScriptElement>("[data-q-tags]");
	if (!manifestEl || !tagsEl) {
		throw new Error("tagfs page is missing its manifest");
	}
	const manifest: ManifestItem[] = JSON.parse(manifestEl.textContent ?? "[]");
	const allTags: string[] = JSON.parse(tagsEl.textContent ?? "[]");
	const allTagSet = new Set(allTags);

	function readSegments(): string[] {
		const url = new URL(window.location.href);
		const pParam = url.searchParams.get("p");
		if (pParam) {
			const decoded = decodeURIComponent(pParam)
				.replace(/^\/+/, "")
				.replace(/\/+$/, "");
			const newPath = decoded ? `${ROOT}${decoded}/` : ROOT;
			window.history.replaceState(null, "", newPath + url.hash);
		}
		const path = window.location.pathname;
		const rest = path.startsWith(ROOT) ? path.slice(ROOT.length) : "";
		return rest.split("/").filter(Boolean);
	}

	function escapeAttr(s: string): string {
		return s
			.replace(/&/g, "&amp;")
			.replace(/"/g, "&quot;")
			.replace(/</g, "&lt;")
			.replace(/>/g, "&gt;");
	}

	function tagRefineHTML(
		segments: string[],
		tags: string[],
		present: Set<string>,
	): string {
		const isRoot = segments.length === 0;
		const url = (suffix: string[]) =>
			`${ROOT}${[...segments, ...suffix].join("/")}/`;
		const sortedTags = [...tags].sort();
		const items = sortedTags
			.map((t) => {
				const inQuery = present.has(t);
				const accentCls = inQuery
					? "text-accent border-b border-accent/40"
					: "text-fg-dim";
				const browseTitle = isRoot ? `Browse #${t}` : `AND #${t}`;
				const browseAria = isRoot ? `Browse ${t}` : `AND ${t}`;
				const orBtn = isRoot
					? ""
					: `<a href="${escapeAttr(url([t, "or"]))}" class="font-mono text-[16px] leading-none text-fg-faint hover:text-accent px-1.5" title="OR #${escapeAttr(t)}" aria-label="OR ${escapeAttr(t)}">∨</a>`;
				const notTitle = isRoot ? `Exclude #${t}` : `AND NOT #${t}`;
				const notAria = isRoot ? `Exclude ${t}` : `AND NOT ${t}`;
				return `<li class="flex items-baseline gap-3 px-1 py-1 border-b border-rule/40">
					<span class="flex items-baseline gap-1 shrink-0">
						<a href="${escapeAttr(url([t]))}" class="font-mono text-[16px] leading-none text-fg-faint hover:text-accent px-1.5" title="${escapeAttr(browseTitle)}" aria-label="${escapeAttr(browseAria)}">∧</a>
						${orBtn}
						<a href="${escapeAttr(url([t, "not"]))}" class="font-mono text-[16px] leading-none text-fg-faint hover:text-accent px-1.5" title="${escapeAttr(notTitle)}" aria-label="${escapeAttr(notAria)}">¬</a>
					</span>
					<a href="/posts/q/${escapeAttr(t)}/" class="font-mono text-[13px] hover:text-accent transition-colors ${accentCls}" title="Start a new query with #${escapeAttr(t)}">#${escapeAttr(t)}</a>
				</li>`;
			})
			.join("");
		const orHelp = isRoot
			? ""
			: `<span class="normal-case tracking-normal text-[11px]"><span class="text-fg-dim">∨</span> or</span>`;
		const headlineLabel = isRoot ? "Build a query" : "Refine query";
		const negLabel = isRoot ? "exclude" : "and not";
		return `<details class="tag-refine border border-rule rounded-md bg-bg-alt/40">
			<summary class="cursor-pointer select-none px-5 py-3 flex items-center justify-between gap-4 hover:bg-bg-alt/60 transition-colors rounded-md">
				<span class="font-mono text-[10.5px] text-fg-faint uppercase tracking-[0.08em]">
					${headlineLabel}
					<span class="normal-case tracking-normal text-[11px] text-fg-dim ml-2">· ${sortedTags.length} tags · ∧ ∨ ¬</span>
				</span>
				<span class="font-mono text-[11px] text-fg-faint tracking-[0.05em] flex items-center gap-1.5">
					<span class="when-closed">show ▸</span>
					<span class="when-open">hide ▾</span>
				</span>
			</summary>
			<div class="px-5 pb-4 pt-2 border-t border-rule/60">
				<div class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-3 font-mono text-[10.5px] text-fg-faint tracking-[0.08em]">
					<span class="normal-case tracking-normal text-[11px]"><span class="text-fg-dim">tag</span> = new query</span>
					<span class="normal-case tracking-normal text-[11px]"><span class="text-fg-dim">∧</span> and</span>
					${orHelp}
					<span class="normal-case tracking-normal text-[11px]"><span class="text-fg-dim">¬</span> ${negLabel}</span>
				</div>
				<ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-1.5">
					${items}
				</ul>
			</div>
		</details>`;
	}

	function applyQuery(): void {
		const segments = readSegments();
		const isEmpty = segments.length === 0;

		let matchedIds: Set<string>;
		let description = "All posts";
		let kicker = "Posts";

		if (isEmpty) {
			matchedIds = new Set(manifest.map((m) => m.id));
		} else {
			kicker = "Tag query";
			const tokens = parse(segments);
			const result = evaluate(tokens, manifest, (m) => m.tags);
			if (!result.ok) {
				description = "Invalid query";
				matchedIds = new Set();
			} else {
				description = result.description || "All posts";
				matchedIds = new Set(result.items.map((m) => m.id));
			}
		}

		let visibleCount = 0;
		const rows = document.querySelectorAll<HTMLElement>(
			"[data-q-feed] [data-post-id]",
		);
		for (const row of rows) {
			const id = row.dataset.postId ?? "";
			if (matchedIds.has(id)) {
				row.removeAttribute("hidden");
				visibleCount++;
			} else {
				row.setAttribute("hidden", "");
			}
		}

		const titleEl = document.querySelector("[data-q-title]");
		const kickerEl = document.querySelector("[data-q-kicker]");
		const countEl = document.querySelector("[data-q-count]");
		const nounEl = document.querySelector("[data-q-noun]");
		const pathEl = document.querySelector("[data-q-path]");
		const emptyEl = document.querySelector<HTMLElement>("[data-q-empty]");
		const refineWrap = document.querySelector("[data-q-tagrefine]");
		if (titleEl) titleEl.textContent = description;
		if (kickerEl) kickerEl.textContent = kicker;
		if (countEl) countEl.textContent = String(visibleCount);
		if (nounEl) nounEl.textContent = visibleCount === 1 ? "post" : "posts";
		if (pathEl)
			pathEl.textContent = isEmpty
				? "/posts/q/"
				: `/posts/q/${segments.join("/")}/`;
		if (emptyEl) {
			if (visibleCount === 0 && !isEmpty) emptyEl.removeAttribute("hidden");
			else emptyEl.setAttribute("hidden", "");
		}
		if (!isEmpty && refineWrap) {
			const present = new Set(segments.filter((s) => allTagSet.has(s)));
			refineWrap.innerHTML = tagRefineHTML(segments, allTags, present);
		}

		document.title = `${isEmpty ? "Posts" : description} — Append Only`;
	}

	applyQuery();
</script>
