---
import { getCollection } from "astro:content";
import PostFinder from "@/components/PostFinder.astro";
import PageLayout from "@/theme/layouts/PageLayout.astro";
import { effectiveUpdateDate } from "@/lib/post-dates";
import { knownTags } from "@/theme/lib/knownTags";
import { tagSlug } from "@/theme/lib/tags";

const all = await getCollection("posts", ({ data }) => !data.draft && !data.unlisted);
const sorted = [...all].sort((a, b) => {
	const da = effectiveUpdateDate(a).valueOf();
	const db = effectiveUpdateDate(b).valueOf();
	if (db !== da) return db - da;
	return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
});

const allTagSlugs = new Set<string>(knownTags);
for (const p of all) for (const t of p.data.tags) allTagSlugs.add(tagSlug(t));
const allTags = [...allTagSlugs].sort();

const interests = [
	{ display: "probability & stats", slug: "probability-stats" },
	{ display: "voting", slug: "voting" },
	{ display: "game theory", slug: "game-theory" },
	{ display: "rocketry", slug: "rocketry" },
];
---

<PageLayout current="index" title="Reduction · Ben Abbitt">
	<section class="mb-12 max-w-[720px]" data-q-hero>
		<h1
			class="font-serif font-medium text-[48px] sm:text-[72px] leading-none tracking-[-0.025em] mb-5"
		>
			Reduction
		</h1>
		<p class="text-[18px] leading-[1.55] text-fg-dim max-w-[620px]">
			What I build, read, cook, and pour, reduced to what's worth keeping.
			<a href="/?p=software-architecture" class="tagline-link"
				>Software architecture</a
			>,
			<a href="/?p=llm" class="tagline-link">AI wrangling</a>,
			<a href="/?p=technical-learnings" class="tagline-link"
				>technical learnings</a
			>, and
			<a href="/?p=tools" class="tagline-link"
				>the tools I keep reaching for</a
			>. Plus
			<a href="/?p=cocktail" class="tagline-link">cocktails</a>,
			<a href="/?p=food" class="tagline-link">food</a>,
			<a href="/?p=travel" class="tagline-link">travel and tourism</a>,
			<a href="/?p=social-dynamics" class="tagline-link"
				>social dynamics</a
			>, and
			<a href="/?p=culture" class="tagline-link">culture</a>. Notes from
			Ben Abbitt.
		</p>
		<p class="font-serif-body text-[15px] text-fg-dim mt-4 italic">
			<span
				class="font-mono not-italic text-[10.5px] text-fg-faint tracking-[0.08em] uppercase mr-2.5"
				>also thinking about</span
			>
			{
				interests.map((i, ix) => (
					<>
						<a
							href={`/?p=${i.slug}`}
							class="hover:text-accent border-b border-rule/60 hover:border-accent"
						>
							<em>{i.display}</em>
						</a>
						{ix < interests.length - 1 && (
							<span class="text-fg-faint not-italic"> · </span>
						)}
					</>
				))
			}
		</p>
	</section>

	<h2
		class="font-mono font-normal text-[11px] text-fg-faint tracking-[0.12em] uppercase mb-4"
		data-q-feed-label
	>
		Latest
	</h2>

	<PostFinder
		entries={sorted}
		allTags={allTags}
		blog="main"
		kicker="Posts"
		defaultTitle="All posts"
	/>
</PageLayout>

<style>
	.tagline-link {
		color: inherit;
		border-bottom: 1px solid color-mix(in oklab, currentColor 25%, transparent);
		transition: color 0.15s, border-color 0.15s;
	}
	.tagline-link:hover {
		color: var(--color-accent);
		border-bottom-color: var(--color-accent);
	}
</style>
