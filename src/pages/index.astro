---
import { getCollection } from "astro:content";
import PostFeed from "@/components/PostFeed.astro";
import PageLayout from "@/theme/layouts/PageLayout.astro";
import { renderExcerpt } from "@/lib/dish-count";
import { knownTags } from "@/theme/lib/knownTags";
import { tagSlug } from "@/theme/lib/tags";
import { effectiveUpdateDate } from "@/lib/post-dates";

const all = await getCollection("posts", ({ data }) => !data.draft && !data.unlisted);
const sorted = [...all].sort(
	(a, b) => effectiveUpdateDate(b).valueOf() - effectiveUpdateDate(a).valueOf(),
);

const allTagSlugs = new Set<string>(knownTags);
for (const p of all) for (const t of p.data.tags) allTagSlugs.add(tagSlug(t));
const allTags = [...allTagSlugs].sort();

const manifest = sorted.map((p) => ({
	id: p.id,
	tags: p.data.tags.map(tagSlug),
	text: [p.data.title, renderExcerpt(p.data, p.body), p.data.description]
		.filter(Boolean)
		.join(" ")
		.toLowerCase(),
}));

const interests = [
	{ display: "probability & stats", slug: "probability-stats" },
	{ display: "voting", slug: "voting" },
	{ display: "game theory", slug: "game-theory" },
	{ display: "rocketry", slug: "rocketry" },
];
---

<PageLayout current="index" title="Reduction · Ben Abbitt">
	<section class="mb-12 max-w-[720px]" data-q-hero>
		<h1
			class="font-serif font-medium text-[48px] sm:text-[72px] leading-none tracking-[-0.025em] mb-5"
		>
			Reduction
		</h1>
		<p class="text-[18px] leading-[1.55] text-fg-dim max-w-[620px]">
			What I build, read, cook, and pour, reduced to what's worth keeping.
			<a href="/?p=software-architecture" class="tagline-link"
				>Software architecture</a
			>,
			<a href="/?p=llm" class="tagline-link">AI wrangling</a>,
			<a href="/?p=technical-learnings" class="tagline-link"
				>technical learnings</a
			>, and
			<a href="/?p=tools" class="tagline-link"
				>the tools I keep reaching for</a
			>. Plus
			<a href="/?p=cocktail" class="tagline-link">cocktails</a>,
			<a href="/?p=food" class="tagline-link">food</a>,
			<a href="/?p=travel" class="tagline-link">travel and tourism</a>,
			<a href="/?p=social-dynamics" class="tagline-link"
				>social dynamics</a
			>, and
			<a href="/?p=culture" class="tagline-link">culture</a>. Notes from
			Ben Abbitt.
		</p>
		<p class="font-serif-body text-[15px] text-fg-dim mt-4 italic">
			<span
				class="font-mono not-italic text-[10.5px] text-fg-faint tracking-[0.08em] uppercase mr-2.5"
				>also thinking about</span
			>
			{
				interests.map((i, ix) => (
					<>
						<a
							href={`/?p=${i.slug}`}
							class="hover:text-accent border-b border-rule/60 hover:border-accent"
						>
							<em>{i.display}</em>
						</a>
						{ix < interests.length - 1 && (
							<span class="text-fg-faint not-italic"> · </span>
						)}
					</>
				))
			}
		</p>
	</section>

	<header class="mb-10" data-q-header hidden>
		<div
			class="font-mono text-[11px] text-fg-faint tracking-[0.12em] uppercase mb-2"
			data-q-kicker
		>
			Posts
		</div>
		<h1
			class="font-serif font-medium text-[44px] leading-[1.05] tracking-[-0.02em] mb-3"
			data-q-title
		>
			All posts
		</h1>
		<p class="text-fg-dim text-[15px]">
			<span data-q-count>{sorted.length}</span>
			<span data-q-noun>{sorted.length === 1 ? "post" : "posts"}</span>.
		</p>
	</header>

	<div
		class="mb-8 border border-rule rounded-md bg-bg-alt/40 focus-within:border-accent/60 transition-colors"
		data-q-find
	>
		<div class="flex items-baseline gap-3 px-5 py-3">
			<label
				for="q-find"
				class="font-mono text-[10.5px] text-fg-faint uppercase tracking-[0.08em] shrink-0"
			>
				Find
			</label>
			<input
				id="q-find"
				type="search"
				data-q-input
				placeholder="search or #tag (try #food, -#draft, #food|#cocktail)"
				class="flex-1 min-w-0 bg-transparent font-mono text-[13px] text-fg placeholder:text-fg-faint focus:outline-none"
				autocomplete="off"
				spellcheck="false"
			/>
			<button
				type="button"
				data-q-clear
				hidden
				class="font-mono text-[11px] text-fg-faint hover:text-accent shrink-0 px-1.5 py-0.5 border border-rule rounded transition-colors"
				title="Clear all filters"
				aria-label="Clear all filters"
			>
				clear
			</button>
		</div>
		<div
			class="px-5 py-2 border-t border-rule/60 font-mono text-[10.5px] text-fg-faint tracking-[0.04em]"
			data-q-active
			hidden
		>
			<span data-q-active-list></span>
		</div>
		<details class="border-t border-rule/60 tag-disclosure">
			<summary
				class="cursor-pointer select-none px-5 py-2 flex items-center justify-between gap-4 hover:bg-bg-alt/60 transition-colors font-mono text-[10.5px] text-fg-faint uppercase tracking-[0.08em]"
			>
				<span
					>Browse
					<span class="normal-case tracking-normal text-[11px] text-fg-dim ml-2"
						>· {allTags.length} tags · click to add to query</span
					></span
				>
				<span
					class="font-mono text-[11px] text-fg-faint tracking-[0.05em] flex items-center gap-1.5"
				>
					<span class="when-closed">show ▸</span>
					<span class="when-open">hide ▾</span>
				</span>
			</summary>
			<div class="px-5 pb-3 pt-1 flex flex-wrap gap-x-3 gap-y-1.5 items-baseline">
				{
					allTags.map((t) => (
						<button
							type="button"
							data-q-tag={t}
							class="font-mono text-[12px] text-fg-dim hover:text-accent transition-colors"
							title={`Add #${t} to query`}
						>
							#{t}
						</button>
					))
				}
			</div>
		</details>
	</div>

	<h2
		class="font-mono font-normal text-[11px] text-fg-faint tracking-[0.12em] uppercase mb-4"
		data-q-feed-label
	>
		Latest
	</h2>
	<div data-q-feed>
		<PostFeed entries={sorted} showExcerpt />
	</div>
	<p class="text-fg-dim text-[15px] italic mt-4" data-q-empty hidden>
		No posts match this query.
	</p>

	<script
		type="application/json"
		data-q-manifest
		set:html={JSON.stringify(manifest)}
	/>
	<script
		type="application/json"
		data-q-tags
		set:html={JSON.stringify(allTags)}
	/>
</PageLayout>

<script>
	import { evaluate, parse } from "@/lib/tagfs";

	type ManifestItem = { id: string; tags: string[]; text: string };

	const manifestEl = document.querySelector<HTMLScriptElement>(
		"[data-q-manifest]",
	);
	const tagsEl = document.querySelector<HTMLScriptElement>("[data-q-tags]");
	if (!manifestEl || !tagsEl) {
		throw new Error("listing page is missing its manifest");
	}
	const manifest: ManifestItem[] = JSON.parse(manifestEl.textContent ?? "[]");
	const allTags: string[] = JSON.parse(tagsEl.textContent ?? "[]");
	const allTagSet = new Set(allTags);

	type ParsedInput = {
		segments: string[];
		search: string;
		activeTokens: { kind: "tag" | "not" | "or" | "text"; value: string }[];
	};

	// Parse the smart-input string into URL state + a token list for display.
	// Grammar:
	//   #tag           → AND tag
	//   -#tag, !#tag   → AND NOT tag
	//   -tag,  !tag    → AND NOT tag (bare form)
	//   #a|#b          → tag OR group (any number of |-joined tags)
	//   plain word     → text search (multi-word: AND substring)
	function parseInput(input: string): ParsedInput {
		const tokens = input.trim().split(/\s+/).filter(Boolean);
		const segments: string[] = [];
		const searchWords: string[] = [];
		const activeTokens: ParsedInput["activeTokens"] = [];

		for (const tok of tokens) {
			if (tok.startsWith("-#") || tok.startsWith("!#")) {
				const tag = tok.slice(2).toLowerCase();
				if (tag) {
					segments.push(tag, "not");
					activeTokens.push({ kind: "not", value: tag });
				}
			} else if ((tok.startsWith("-") || tok.startsWith("!")) && tok.length > 1 && !tok.includes("#")) {
				const tag = tok.slice(1).toLowerCase();
				if (tag) {
					segments.push(tag, "not");
					activeTokens.push({ kind: "not", value: tag });
				}
			} else if (tok.startsWith("#")) {
				const orParts = tok
					.split("|")
					.map((p) => p.replace(/^#/, "").toLowerCase())
					.filter(Boolean);
				if (orParts.length === 1) {
					segments.push(orParts[0]);
					activeTokens.push({ kind: "tag", value: orParts[0] });
				} else if (orParts.length > 1) {
					segments.push(orParts[0]);
					for (let i = 1; i < orParts.length; i++) {
						segments.push(orParts[i], "or");
					}
					activeTokens.push({ kind: "or", value: orParts.join("|") });
				}
			} else {
				searchWords.push(tok);
			}
		}

		const search = searchWords.join(" ");
		if (search) activeTokens.push({ kind: "text", value: search });
		return { segments, search, activeTokens };
	}

	// Format URL state back into a smart-input string.
	// Walks postfix-RPN segments to reconstruct fragments; falls back to
	// space-joining any remaining stack as implicit AND.
	function formatInput(segments: string[], search: string): string {
		const stack: string[] = [];
		for (const seg of segments) {
			const lower = seg.toLowerCase();
			if (lower === "and") {
				if (stack.length >= 2) {
					const b = stack.pop() as string;
					const a = stack.pop() as string;
					stack.push(`${a} ${b}`);
				}
			} else if (lower === "or") {
				if (stack.length >= 2) {
					const b = stack.pop() as string;
					const a = stack.pop() as string;
					stack.push(`${a}|${b}`);
				}
			} else if (lower === "not") {
				if (stack.length >= 1) {
					const a = stack.pop() as string;
					stack.push(a.startsWith("#") ? `-${a}` : `-(${a})`);
				}
			} else {
				stack.push(`#${seg}`);
			}
		}
		const tagPart = stack.join(" ");
		return [tagPart, search].filter(Boolean).join(" ");
	}

	function readURLState(): { segments: string[]; search: string } {
		const url = new URL(window.location.href);
		const pParam = url.searchParams.get("p") ?? "";
		const sParam = url.searchParams.get("s") ?? "";
		const segments = decodeURIComponent(pParam)
			.replace(/^\/+/, "")
			.replace(/\/+$/, "")
			.split("/")
			.filter(Boolean);
		return { segments, search: sParam.trim().toLowerCase() };
	}

	function writeURLState(segments: string[], search: string): void {
		const url = new URL(window.location.href);
		const trimmed = search.trim();
		if (segments.length > 0) url.searchParams.set("p", segments.join("/"));
		else url.searchParams.delete("p");
		if (trimmed) url.searchParams.set("s", trimmed);
		else url.searchParams.delete("s");
		window.history.replaceState(null, "", url.toString());
	}

	function renderActive(
		tokens: ParsedInput["activeTokens"],
		listEl: HTMLElement,
	): void {
		listEl.textContent = "";
		const parts: string[] = [];
		for (const tok of tokens) {
			if (tok.kind === "tag") parts.push(`#${tok.value}`);
			else if (tok.kind === "not") parts.push(`-#${tok.value}`);
			else if (tok.kind === "or") parts.push(tok.value);
			else if (tok.kind === "text") parts.push(`"${tok.value}"`);
		}
		listEl.textContent = `${tokens.length} active: ${parts.join(" · ")}`;
	}

	function applyQuery(): void {
		const { segments, search } = readURLState();
		const isEmpty = segments.length === 0;
		const filtered = !isEmpty || !!search;

		let matchedIds: Set<string>;
		let description = "All posts";
		let kicker = "Posts";

		if (isEmpty) {
			matchedIds = new Set(manifest.map((m) => m.id));
		} else {
			kicker = "Tag query";
			const tokens = parse(segments);
			const result = evaluate(tokens, manifest, (m) => m.tags);
			if (!result.ok) {
				description = "Invalid query";
				matchedIds = new Set();
			} else {
				description = result.description || "All posts";
				matchedIds = new Set(result.items.map((m) => m.id));
			}
		}

		if (search) {
			const filteredIds = new Set<string>();
			for (const m of manifest) {
				if (matchedIds.has(m.id) && m.text.includes(search)) {
					filteredIds.add(m.id);
				}
			}
			matchedIds = filteredIds;
			if (isEmpty) {
				kicker = "Search";
				description = `Search: "${search}"`;
			} else {
				description = `${description} · "${search}"`;
			}
		}

		let visibleCount = 0;
		const rows = document.querySelectorAll<HTMLElement>(
			"[data-q-feed] [data-post-id]",
		);
		for (const row of rows) {
			const id = row.dataset.postId ?? "";
			if (matchedIds.has(id)) {
				row.removeAttribute("hidden");
				visibleCount++;
			} else {
				row.setAttribute("hidden", "");
			}
		}

		const heroEl = document.querySelector<HTMLElement>("[data-q-hero]");
		const headerEl = document.querySelector<HTMLElement>("[data-q-header]");
		const titleEl = document.querySelector("[data-q-title]");
		const kickerEl = document.querySelector("[data-q-kicker]");
		const countEl = document.querySelector("[data-q-count]");
		const nounEl = document.querySelector("[data-q-noun]");
		const emptyEl = document.querySelector<HTMLElement>("[data-q-empty]");
		const feedLabel = document.querySelector<HTMLElement>("[data-q-feed-label]");
		const clearBtn = document.querySelector<HTMLElement>("[data-q-clear]");
		const activeWrap = document.querySelector<HTMLElement>("[data-q-active]");
		const activeList = document.querySelector<HTMLElement>("[data-q-active-list]");

		if (heroEl) {
			if (filtered) heroEl.setAttribute("hidden", "");
			else heroEl.removeAttribute("hidden");
		}
		if (headerEl) {
			if (filtered) headerEl.removeAttribute("hidden");
			else headerEl.setAttribute("hidden", "");
		}
		if (feedLabel) {
			if (filtered) feedLabel.setAttribute("hidden", "");
			else feedLabel.removeAttribute("hidden");
		}
		if (titleEl) titleEl.textContent = description;
		if (kickerEl) kickerEl.textContent = kicker;
		if (countEl) countEl.textContent = String(visibleCount);
		if (nounEl) nounEl.textContent = visibleCount === 1 ? "post" : "posts";
		if (emptyEl) {
			if (visibleCount === 0 && filtered) emptyEl.removeAttribute("hidden");
			else emptyEl.setAttribute("hidden", "");
		}
		if (clearBtn) {
			if (filtered) clearBtn.removeAttribute("hidden");
			else clearBtn.setAttribute("hidden", "");
		}

		// Active-tokens summary line, derived from current input
		const inputEl = document.querySelector<HTMLInputElement>("[data-q-input]");
		const inputVal = inputEl?.value ?? "";
		const parsed = parseInput(inputVal);
		if (activeWrap && activeList) {
			if (parsed.activeTokens.length > 0) {
				renderActive(parsed.activeTokens, activeList);
				activeWrap.removeAttribute("hidden");
			} else {
				activeList.textContent = "";
				activeWrap.setAttribute("hidden", "");
			}
		}

		// Tag chips: highlight active tags
		const activeTagSet = new Set(
			segments.filter((s) => allTagSet.has(s.toLowerCase())).map((s) => s.toLowerCase()),
		);
		for (const btn of document.querySelectorAll<HTMLButtonElement>("[data-q-tag]")) {
			const t = btn.dataset.qTag ?? "";
			if (activeTagSet.has(t)) {
				btn.classList.add("text-accent");
				btn.classList.remove("text-fg-dim");
			} else {
				btn.classList.add("text-fg-dim");
				btn.classList.remove("text-accent");
			}
		}

		document.title = filtered
			? `${description} · Reduction`
			: "Reduction · Ben Abbitt";
	}

	function syncFromInput(value: string): void {
		const { segments, search } = parseInput(value);
		writeURLState(segments, search);
		applyQuery();
	}

	function syncToInput(): void {
		const { segments, search } = readURLState();
		const inputEl = document.querySelector<HTMLInputElement>("[data-q-input]");
		if (inputEl) inputEl.value = formatInput(segments, search);
	}

	// Initialize input from URL, then wire events
	syncToInput();

	const inputEl = document.querySelector<HTMLInputElement>("[data-q-input]");
	if (inputEl) {
		inputEl.addEventListener("input", () => {
			syncFromInput(inputEl.value);
		});
	}

	const clearBtn = document.querySelector<HTMLElement>("[data-q-clear]");
	if (clearBtn) {
		clearBtn.addEventListener("click", () => {
			if (inputEl) inputEl.value = "";
			writeURLState([], "");
			applyQuery();
			inputEl?.focus();
		});
	}

	// Click a tag chip → append (or remove if already present) #tag in the input
	for (const btn of document.querySelectorAll<HTMLButtonElement>("[data-q-tag]")) {
		btn.addEventListener("click", () => {
			if (!inputEl) return;
			const tag = btn.dataset.qTag ?? "";
			if (!tag) return;
			const current = inputEl.value;
			const tokens = current.trim().split(/\s+/).filter(Boolean);
			const presentIdx = tokens.findIndex(
				(t) => t.toLowerCase() === `#${tag}`,
			);
			if (presentIdx >= 0) {
				tokens.splice(presentIdx, 1);
			} else {
				tokens.push(`#${tag}`);
			}
			inputEl.value = tokens.join(" ");
			syncFromInput(inputEl.value);
			inputEl.focus();
		});
	}

	applyQuery();
</script>

<style>
	.tagline-link {
		color: inherit;
		border-bottom: 1px solid color-mix(in oklab, currentColor 25%, transparent);
		transition: color 0.15s, border-color 0.15s;
	}
	.tagline-link:hover {
		color: var(--color-accent);
		border-bottom-color: var(--color-accent);
	}
	.tag-disclosure[open] .when-closed {
		display: none;
	}
	.tag-disclosure:not([open]) .when-open {
		display: none;
	}
</style>
