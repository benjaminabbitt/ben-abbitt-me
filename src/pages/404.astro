---
import PageLayout from "@/theme/layouts/PageLayout.astro";
---

<PageLayout title="Not found · Reduction" description="Page not found.">
	<script is:inline>
		(function () {
			var path = window.location.pathname;
			var hash = window.location.hash || "";
			var search = window.location.search || "";
			// /posts/modern-forage-{slug}/ → /forage/{slug}/  (collection split)
			var mfMatch = path.match(/^\/posts\/modern-forage-([a-z0-9-]+)\/?$/);
			if (mfMatch) {
				window.location.replace("/forage/" + mfMatch[1] + "/" + search + hash);
				return;
			}
			// /posts/q/modern-forage[anything] → /forage-atlas/  (forage tag query
			// no longer makes sense once forage left the posts collection)
			if (path.indexOf("/posts/q/modern-forage") === 0) {
				window.location.replace("/forage-atlas/" + hash);
				return;
			}
			// /posts/q/{segments}/ → /?p={segments}  (other tag queries land on main blog)
			var qPrefix = "/posts/q/";
			if (path.indexOf(qPrefix) === 0) {
				var rest = path.slice(qPrefix.length).replace(/^\/+/, "").replace(/\/+$/, "");
				if (rest) {
					window.location.replace("/?p=" + encodeURIComponent(rest) + hash);
				} else {
					window.location.replace("/" + search + hash);
				}
				return;
			}
			if (path === "/posts" || path === "/posts/") {
				window.location.replace("/" + search + hash);
				return;
			}
		})();
	</script>

	<div class="max-w-[640px] mx-auto py-20 text-center">
		<div
			class="font-mono text-[11px] text-fg-faint tracking-[0.12em] uppercase mb-3"
		>
			404
		</div>
		<h1
			class="font-serif font-medium text-[44px] leading-[1.05] tracking-[-0.02em] mb-4"
		>
			Not found
		</h1>
		<p class="text-fg-dim text-[15px] mb-8">
			This page doesn't exist, or it moved. The address bar still shows where
			you tried to go.
		</p>
		<p class="font-mono text-[12px]">
			<a href="/" class="text-accent hover:underline">/ home</a>
			<span class="text-fg-faint mx-2">·</span>
			<a href="/projects/" class="text-accent hover:underline">/projects/</a>
			<span class="text-fg-faint mx-2">·</span>
			<a href="/resume/" class="text-accent hover:underline">/resume/</a>
		</p>
	</div>
</PageLayout>
