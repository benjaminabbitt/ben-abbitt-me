---
interface Props {
	segments: readonly string[];
	allTags: readonly string[];
	presentTags: ReadonlySet<string>;
}
const { segments, allTags, presentTags } = Astro.props;

const isRoot = segments.length === 0;

function url(suffix: readonly string[]): string {
	const parts = [...segments, ...suffix];
	return `/posts/q/${parts.join("/")}/`;
}

const sortedTags = [...allTags].sort();
---

<details class="tag-refine border border-rule rounded-md bg-bg-alt/40">
	<summary
		class="cursor-pointer select-none px-5 py-3 flex items-center justify-between gap-4 hover:bg-bg-alt/60 transition-colors rounded-md"
	>
		<span
			class="font-mono text-[10.5px] text-fg-faint uppercase tracking-[0.08em]"
		>
			{isRoot ? "Build a query" : "Refine query"}
			<span class="normal-case tracking-normal text-[11px] text-fg-dim ml-2">
				· {sortedTags.length} tags · ∧ ∨ ¬
			</span>
		</span>
		<span
			class="font-mono text-[11px] text-fg-faint tracking-[0.05em] flex items-center gap-1.5"
		>
			<span class="when-closed">show ▸</span>
			<span class="when-open">hide ▾</span>
		</span>
	</summary>

	<div class="px-5 pb-4 pt-2 border-t border-rule/60">
		<div
			class="flex flex-wrap items-baseline gap-x-4 gap-y-1 mb-3 font-mono text-[10.5px] text-fg-faint tracking-[0.08em]"
		>
			<span class="normal-case tracking-normal text-[11px]"
				><span class="text-fg-dim">tag</span> = new query</span
			>
			<span class="normal-case tracking-normal text-[11px]"
				><span class="text-fg-dim">∧</span> and</span
			>
			{
				!isRoot && (
					<span class="normal-case tracking-normal text-[11px]">
						<span class="text-fg-dim">∨</span> or
					</span>
				)
			}
			<span class="normal-case tracking-normal text-[11px]"
				><span class="text-fg-dim">¬</span>
				{isRoot ? "exclude" : "and not"}</span
			>
		</div>
		<ul class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-1.5">
			{
				sortedTags.map((t) => {
					const inQuery = presentTags.has(t);
					return (
						<li class="flex items-baseline gap-3 px-1 py-1 border-b border-rule/40">
							<span class="flex items-baseline gap-1 shrink-0">
								<a
									href={url([t])}
									class="font-mono text-[16px] leading-none text-fg-faint hover:text-accent px-1.5"
									title={isRoot ? `Browse #${t}` : `AND #${t}`}
									aria-label={isRoot ? `Browse ${t}` : `AND ${t}`}
								>
									∧
								</a>
								{!isRoot && (
									<a
										href={url([t, "or"])}
										class="font-mono text-[16px] leading-none text-fg-faint hover:text-accent px-1.5"
										title={`OR #${t}`}
										aria-label={`OR ${t}`}
									>
										∨
									</a>
								)}
								<a
									href={url([t, "not"])}
									class="font-mono text-[16px] leading-none text-fg-faint hover:text-accent px-1.5"
									title={isRoot ? `Exclude #${t}` : `AND NOT #${t}`}
									aria-label={isRoot ? `Exclude ${t}` : `AND NOT ${t}`}
								>
									¬
								</a>
							</span>
							<a
								href={`/posts/q/${t}/`}
								class:list={[
									"font-mono text-[13px] hover:text-accent transition-colors",
									inQuery
										? "text-accent border-b border-accent/40"
										: "text-fg-dim",
								]}
								title={`Start a new query with #${t}`}
							>
								#{t}
							</a>
						</li>
					);
				})
			}
		</ul>
	</div>
</details>

<style>
	.tag-refine summary {
		list-style: none;
	}
	.tag-refine summary::-webkit-details-marker {
		display: none;
	}
	.tag-refine[open] .when-closed {
		display: none;
	}
	.tag-refine:not([open]) .when-open {
		display: none;
	}
</style>
