---
import BWAMark from "./BWAMark.astro";
import Nav from "./Nav.astro";

type Section = "index" | "posts" | "forage" | "projects" | "resume";
interface Props {
	current?: Section | undefined;
}
const { current } = Astro.props;
---

<header class="flex flex-wrap items-center justify-between gap-x-6 gap-y-3 pt-7 pb-9 border-b border-rule mb-12">
	<a
		href="/"
		class="inline-flex items-center gap-3 text-fg hover:text-fg"
		aria-label="Reduction · home"
	>
		<span class="inline-flex"><BWAMark size={28} stroke={9} /></span>
		<span class="font-serif font-medium text-[19px] tracking-[-0.01em]"
			>Reduction</span
		>
	</a>
	<Nav current={current} />
</header>
