---
type Section = "index" | "posts" | "forage" | "projects" | "resume";
interface Props {
	current?: Section | undefined;
}
const { current } = Astro.props;

const items = [
	{ id: "index", label: "index", href: "/" },
	{ id: "forage", label: "modern forage", href: "/forage-atlas/" },
	{ id: "projects", label: "projects", href: "/projects/" },
	{ id: "resume", label: "résumé", href: "/resume/" },
] as const;
---

<nav class="flex flex-wrap gap-x-4 sm:gap-x-5 gap-y-1 font-mono text-[12.5px]" aria-label="Primary">
	{
		items.map((it) => (
			<a
				href={it.href}
				aria-current={current === it.id ? "page" : undefined}
				class:list={[
					"transition-colors duration-150 hover:text-accent",
					current === it.id ? "nav-active text-fg" : "text-fg-dim",
				]}
			>
				{it.label}
			</a>
		))
	}
</nav>

<style>
	/* "·" prefix on active item — needs ::before, not expressible in utility classes. */
	.nav-active::before {
		content: "· ";
		color: var(--color-accent);
	}
</style>
