---
import PaletteToggle from "../components/PaletteToggle.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "./BaseLayout.astro";

type Section = "index" | "posts" | "forage" | "projects" | "resume";
interface Props {
	title?: string | undefined;
	description?: string | undefined;
	current?: Section | undefined;
	noindex?: boolean | undefined;
}
const { title, description, current, noindex } = Astro.props;
---

<BaseLayout title={title} description={description} noindex={noindex}>
	<div class="max-w-[1040px] mx-auto px-5 sm:px-8 pb-15 sm:pb-20">
		<SiteHeader current={current} />
		<main>
			<slot />
		</main>
		<footer
			class="no-print flex flex-wrap justify-between gap-x-4 gap-y-1 border-t border-rule mt-20 pt-6 font-mono text-[11px] text-fg-faint"
		>
			<span>Reduction · Ben Abbitt · {new Date().getFullYear()}</span>
			<span>
				<a
					href="https://creativecommons.org/licenses/by-sa/4.0/"
					rel="license noopener"
					class="hover:text-accent"
					>CC BY-SA 4.0</a
				>
			</span>
			<span>ben.abbitt.me</span>
		</footer>
	</div>
	<PaletteToggle />
</BaseLayout>
