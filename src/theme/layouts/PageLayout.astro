---
import PaletteToggle from "../components/PaletteToggle.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BaseLayout from "./BaseLayout.astro";

type Section = "index" | "posts" | "forage" | "projects" | "resume";
interface Props {
	title?: string | undefined;
	description?: string | undefined;
	current?: Section | undefined;
}
const { title, description, current } = Astro.props;
---

<BaseLayout title={title} description={description}>
	<div class="max-w-[1040px] mx-auto px-5 sm:px-8 pb-15 sm:pb-20">
		<SiteHeader current={current} />
		<main>
			<slot />
		</main>
		<footer
			class="no-print flex justify-between border-t border-rule mt-20 pt-6 font-mono text-[11px] text-fg-faint"
		>
			<span>Reduction · Ben Abbitt · {new Date().getFullYear()}</span>
			<span>ben.abbitt.me</span>
		</footer>
	</div>
	<PaletteToggle />
</BaseLayout>
